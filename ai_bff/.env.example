AI_LOGIN_API_BASE_URL=http://localhost:8080
AI_MODEL_PROVIDER=openai_compatible
# DashScope OpenAI-compatible endpoint (Beijing). Use dashscope-intl.aliyuncs.com for intl.
AI_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_API_KEY=
AI_MODEL_NAME=qwen3-vl-plus
AI_MODEL_TEMPERATURE=0.3
AI_MODEL_MAX_TOKENS=1200
AI_MODEL_TIMEOUT=30
AI_BFF_HOST=0.0.0.0
AI_BFF_PORT=8000
# Must match Login_api application.yml jwt.secret (base64-encoded HMAC key).
AI_JWT_SECRET=
# Local dev only. Default false — never enable in production.
AI_AUTH_DISABLED=false
AI_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8082,http://127.0.0.1:8082
# Input length limits (P1-3)
AI_MAX_MESSAGE_CHARS=4000
AI_MAX_DRAFT_INPUT_CHARS=4000
AI_MAX_KEYWORD_TEXT_CHARS=4000
AI_MAX_SITE_SEARCH_KEYWORD_CHARS=200
AI_MAX_CONTEXT_PREVIEW_CHARS=2000
