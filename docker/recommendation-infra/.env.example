MLFLOW_HOST_PORT=5001
MLOPS_HOST_PORT=8090
MLOPS_TRACKING_URI=http://mlflow:5000
MLOPS_MODEL_NAME=recommend_coarse_rank
MLOPS_MODEL_TYPE=lightgbm
MLOPS_KAFKA_BOOTSTRAP_SERVERS=kafka:19092
BGE_HOST_PORT=8088
BGE_MODEL_NAME=BAAI/bge-base-zh-v1.5
BGE_DEVICE=cpu
BGE_BATCH_SIZE=32
# Optional when HuggingFace download is slow:
# HF_ENDPOINT=https://hf-mirror.com
FEAST_HOST_PORT=6566
TRITON_HTTP_PORT=8000
TRITON_GRPC_PORT=8001
TRITON_METRICS_PORT=8002

# Feast online store -> WSL Redis (same as spring.redis.host in Login_api/application.yml).
# Get current WSL IP: wsl hostname -I
FEAST_REDIS_CONNECTION=172.24.198.86:6379
